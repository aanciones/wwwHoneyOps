<% content_for :title, "Contact HoneyOps | Sales" %>
<% content_for :meta_description, "Get in touch with HoneyOps sales for deployments, onboarding, and commercial questions." %>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <%= render "main/site_header", active: :contact %>

  <main>
    <section class="border-b border-slate-900 bg-slate-950 py-20">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-amber-400">Contact</div>
        <h1 class="text-4xl font-bold tracking-tight text-slate-100 sm:text-5xl">
          Talk to our sales team
        </h1>
        <p class="mx-auto mt-5 max-w-3xl text-lg leading-8 text-slate-300">
          For commercial questions, deployment planning, or onboarding details, send us an email and we will get back to you.
        </p>

        <div class="mt-10">
          <a
            href="mailto:sales@honeyops.net"
            class="inline-flex items-center gap-2 rounded-xl bg-amber-500 px-6 py-3 text-base font-semibold text-slate-950 shadow hover:bg-amber-400"
          >
            <%= honey_icon(:mail, classes: "h-5 w-5 text-slate-950") %>
            sales@honeyops.net
          </a>
        </div>
      </div>
    </section>
  </main>

  <%= render "main/site_footer" %>
</div>
