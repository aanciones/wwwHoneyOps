<% content_for :title, "HoneyOps | Honeypots as a Service" %>
<% content_for :meta_description, "Deploy realistic honeypots in minutes. HoneyOps supports OVA appliances and Windows agents with centralized alerts, policies, and reporting." %>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <%= render "main/site_header", active: :home %>

  <main>
    <section class="relative overflow-hidden border-b border-slate-900">
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(1100px_560px_at_50%_-90px,rgba(245,158,11,0.18),transparent)]"></div>
      <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-20 lg:grid-cols-2">
        <div>
          <div class="mb-4 flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-sm text-amber-200">
              <%= honey_icon(:shield, classes: "h-4 w-4") %> Deception-first security
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-sm text-amber-200">
              <%= honey_icon(:server, classes: "h-4 w-4") %> OVA + Windows agent
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-sm text-amber-200">
              <%= honey_icon(:network, classes: "h-4 w-4") %> On-prem and cloud
            </span>
          </div>

          <h1 class="text-4xl font-extrabold tracking-tight text-slate-100 sm:text-6xl">
            Honeypots as a Service
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-300">
            Set up a powerful intrusion-detection trap in minutes — simple to deploy, effortless to manage, and ready to alert you at the first sign of trouble. HoneyOps delivers realistic decoys as a lightweight .ova VM or a native Windows agent, managed from a single secure console.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <%= link_to "How it works", how_it_works_path, class: "inline-flex items-center justify-center rounded-xl bg-amber-500 px-5 py-3 font-semibold text-slate-950 shadow hover:bg-amber-400" %>
            <%= link_to "See pricing", pricing_path, class: "inline-flex items-center gap-2 rounded-xl border border-slate-700 px-5 py-3 font-semibold text-slate-200 hover:bg-slate-900" %>
          </div>

          <p class="mt-4 text-xs text-slate-400">
            Start with 1 trial honeypot for 30 days. Then $10/month per active honeypot.
          </p>
        </div>

        <div class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-xl backdrop-blur">
          <div class="mb-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-amber-400"><%= honey_icon(:cpu, classes: "h-5 w-5") %></span>
              <span class="text-sm font-semibold text-slate-100">Deployment preview</span>
            </div>
            <span class="rounded-full bg-emerald-400/15 px-2 py-1 text-xs font-semibold text-emerald-300">Ready</span>
          </div>

          <div class="overflow-hidden rounded-xl border border-slate-800 bg-black shadow-inner">
            <img src="/hpot_screen.png" alt="HoneyOps deployment screen" class="w-full object-cover">
          </div>

          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li class="flex items-center gap-2">
              <%= honey_icon(:download, classes: "h-4 w-4 text-amber-400") %>
              Download your package (<code class="text-amber-300">.ova</code> or Windows agent)
            </li>
            <li class="flex items-center gap-2">
              <%= honey_icon(:key, classes: "h-4 w-4 text-amber-400") %>
              Pair securely with a one-time enrollment token
            </li>
            <li class="flex items-center gap-2">
              <%= honey_icon(:bell, classes: "h-4 w-4 text-amber-400") %>
              Route alerts to email, webhook, or SIEM destinations
            </li>
          </ul>
        </div>
      </div>
    </section>

    <section class="border-b border-slate-900 bg-slate-950 py-16">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto mb-10 max-w-3xl text-center">
          <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-amber-400">Platform</div>
          <h2 class="text-3xl font-bold tracking-tight text-slate-100 sm:text-4xl">
            A complete honeypot operations platform
          </h2>
          <p class="mt-3 text-slate-300">
            HoneyOps covers the full lifecycle: deploy realistic decoys, enforce policies, monitor health,
            triage alerts, and report on security activity from one central console.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <% [
            { icon: :server, title: "Honeypot inventory", desc: "Create, pair, tag, and monitor honeypots across sites, business units, and networks." },
            { icon: :settings, title: "Policy engine", desc: "Define per-honeypot behavior: incident destination, heartbeat cadence, mute periods, and maintenance windows." },
            { icon: :activity, title: "Security telemetry", desc: "Capture interaction events with enough context for incident triage and forensic investigation." },
            { icon: :bell, title: "Incident alerts", desc: "Automatically open trackable alerts when decoys are touched, with status workflows for response teams." },
            { icon: :report, title: "Reporting", desc: "Generate weekly, monthly, and on-demand reports for technical teams and business stakeholders." },
            { icon: :users, title: "Users and roles", desc: "Use role-based access control so every team member sees and changes only what they should." }
          ].each do |feature| %>
            <article class="rounded-2xl border border-slate-800 bg-slate-900 p-6">
              <div class="mb-4 inline-flex rounded-xl bg-amber-500/15 p-3 text-amber-300">
                <%= honey_icon(feature[:icon], classes: "h-6 w-6") %>
              </div>
              <h3 class="text-lg font-semibold text-slate-100"><%= feature[:title] %></h3>
              <p class="mt-2 text-sm text-slate-300"><%= feature[:desc] %></p>
            </article>
          <% end %>
        </div>
      </div>
    </section>

    <section class="border-b border-slate-900 bg-slate-950/95 py-16">
      <div class="mx-auto grid max-w-7xl gap-10 px-6 lg:grid-cols-2 lg:items-center">
        <div>
          <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-amber-400">Why honeypots</div>
          <h2 class="text-3xl font-bold tracking-tight text-slate-100 sm:text-4xl">
            A tripwire for the moments prevention fails
          </h2>
          <p class="mt-4 text-slate-300">
            Firewalls, endpoint controls, and MFA reduce risk, but no preventive stack is perfect.
            HoneyOps adds a low-noise detection layer inside your environment, where attacker behavior
            becomes visible as soon as decoys are touched.
          </p>
          <ul class="mt-6 space-y-2 text-sm text-slate-300">
            <li class="flex items-start gap-2">
              <span class="mt-1 inline-block h-1.5 w-8 rounded-full bg-amber-400/70"></span>
              <span>Assume breach and detect lateral movement early.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1 inline-block h-1.5 w-8 rounded-full bg-amber-400/70"></span>
              <span>Convert attacker curiosity into high-confidence signal.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1 inline-block h-1.5 w-8 rounded-full bg-amber-400/70"></span>
              <span>Gain response time before production assets are impacted.</span>
            </li>
          </ul>
        </div>

        <div class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-xl">
          <div class="mb-4 text-xs font-semibold uppercase tracking-widest text-slate-400">
            Detection flow
          </div>
          <ol class="space-y-3 text-sm text-slate-300">
            <li><span class="font-semibold text-amber-300">1.</span> Attacker bypasses outer controls and enters the network.</li>
            <li><span class="font-semibold text-amber-300">2.</span> Reconnaissance or lateral movement reaches a HoneyOps decoy.</li>
            <li><span class="font-semibold text-amber-300">3.</span> HoneyOps creates a structured incident alert with technical context.</li>
            <li><span class="font-semibold text-amber-300">4.</span> Your team investigates and contains activity before further spread.</li>
          </ol>
          <div class="mt-6 flex flex-wrap gap-3">
            <%= link_to "How it works", how_it_works_path, class: "inline-flex rounded-xl border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-200 hover:bg-slate-800" %>
            <%= link_to "See integrations", integrations_path, class: "inline-flex rounded-xl bg-amber-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-amber-400" %>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-slate-950 py-16">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
          <div class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-900/70 p-8">
            <div class="absolute inset-0 -z-10 bg-[radial-gradient(600px_300px_at_10%_0%,rgba(245,158,11,0.16),transparent)]"></div>

            <p class="text-xs font-semibold uppercase tracking-widest text-amber-400">Platform snapshot</p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-100 sm:text-4xl">
              Real-world adoption and measurable signal
            </h2>
            <p class="mt-3 max-w-2xl text-sm text-slate-300">
              HoneyOps is built for teams that need practical detection outcomes, not dashboard noise.
            </p>

            <div class="mt-8 grid gap-4 sm:grid-cols-3">
              <div class="rounded-2xl border border-amber-500/40 bg-amber-500/10 p-4">
                <p class="text-3xl font-extrabold text-amber-300">500+</p>
                <p class="mt-1 text-xs uppercase tracking-wider text-amber-100">Active honeypots</p>
              </div>
              <div class="rounded-2xl border border-slate-700 bg-slate-950/70 p-4">
                <p class="text-3xl font-extrabold text-slate-100">300+</p>
                <p class="mt-1 text-xs uppercase tracking-wider text-slate-300">Satisfied customers</p>
              </div>
              <div class="rounded-2xl border border-slate-700 bg-slate-950/70 p-4">
                <p class="text-3xl font-extrabold text-slate-100">24/7</p>
                <p class="mt-1 text-xs uppercase tracking-wider text-slate-300">Continuous detection</p>
              </div>
            </div>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900 p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">Explore the platform</p>
            <div class="mt-4 divide-y divide-slate-800">
              <%= link_to how_it_works_path, class: "group flex items-center justify-between py-4" do %>
                <div>
                  <p class="text-sm font-semibold text-slate-100 group-hover:text-amber-300">How it works</p>
                  <p class="text-xs text-slate-400">Deployment to first alert</p>
                </div>
                <span class="text-slate-500 group-hover:text-amber-300">-></span>
              <% end %>

              <%= link_to integrations_path, class: "group flex items-center justify-between py-4" do %>
                <div>
                  <p class="text-sm font-semibold text-slate-100 group-hover:text-amber-300">Integrations</p>
                  <p class="text-xs text-slate-400">Zabbix and alert pipelines</p>
                </div>
                <span class="text-slate-500 group-hover:text-amber-300">-></span>
              <% end %>

              <%= link_to pricing_path, class: "group flex items-center justify-between py-4" do %>
                <div>
                  <p class="text-sm font-semibold text-slate-100 group-hover:text-amber-300">Pricing</p>
                  <p class="text-xs text-slate-400">Trial and per-honeypot plan</p>
                </div>
                <span class="text-slate-500 group-hover:text-amber-300">-></span>
              <% end %>

              <%= link_to faq_path, class: "group flex items-center justify-between py-4" do %>
                <div>
                  <p class="text-sm font-semibold text-slate-100 group-hover:text-amber-300">FAQ</p>
                  <p class="text-xs text-slate-400">Common deployment questions</p>
                </div>
                <span class="text-slate-500 group-hover:text-amber-300">-></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%= render "main/site_footer" %>
</div>
