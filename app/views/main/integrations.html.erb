<% content_for :title, "HoneyOps Integrations | Zabbix and Alert Pipelines" %>
<% content_for :meta_description, "Connect HoneyOps alerts to Zabbix and your security operations pipeline. Centralize detection events in the tools your team already monitors." %>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <%= render "main/site_header", active: :integrations %>

  <main>
    <section class="border-b border-slate-900 bg-slate-950 py-16">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-2 text-sm font-semibold uppercase tracking-widest text-amber-400">Integrations</div>
          <h1 class="text-4xl font-bold tracking-tight text-slate-100 sm:text-5xl">
            Bring HoneyOps detections into your existing monitoring stack
          </h1>
          <p class="mt-4 text-lg text-slate-300">
            HoneyOps is designed to plug into your operations workflows so honeypot events are visible
            where your team already investigates incidents.
          </p>
        </div>
      </div>
    </section>

    <section class="border-b border-slate-900 bg-slate-950 py-16">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-10 flex items-center justify-center">
          <img src="/zabbix.png" alt="Zabbix logo" class="h-20 w-auto object-contain sm:h-24" />
        </div>

        <div class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1.1fr_0.9fr]">
          <article class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-sm">
            <div class="mb-2 text-xs font-semibold uppercase tracking-widest text-slate-400">Zabbix monitoring</div>
            <h2 class="text-lg font-semibold text-slate-100">Ready-made Zabbix template</h2>
            <p class="mt-2 text-sm text-slate-300">
              Use your HoneyOps account ID and API secret to connect detections and health status directly into Zabbix dashboards.
            </p>
            <ul class="mt-5 space-y-2 text-sm text-slate-300">
              <li class="flex items-start gap-2"><span class="mt-1 inline-block h-1.5 w-8 rounded-full bg-amber-400/70"></span><span>Detect disconnected honeypots and heartbeat failures.</span></li>
              <li class="flex items-start gap-2"><span class="mt-1 inline-block h-1.5 w-8 rounded-full bg-amber-400/70"></span><span>Trigger high-severity alerts when active incidents are created.</span></li>
              <li class="flex items-start gap-2"><span class="mt-1 inline-block h-1.5 w-8 rounded-full bg-amber-400/70"></span><span>Keep security and infrastructure signals in one operations view.</span></li>
            </ul>
          </article>

          <article class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-sm">
            <div class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-400">What you get</div>
            <div class="space-y-4 text-sm text-slate-300">
              <div class="flex items-start gap-3">
                <span class="mt-0.5 text-amber-400"><%= honey_icon(:bell, classes: "h-4 w-4") %></span>
                <p>Centralized incident visibility and escalation from one pane of glass.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 text-amber-400"><%= honey_icon(:activity, classes: "h-4 w-4") %></span>
                <p>Correlated uptime and security telemetry for faster diagnosis.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 text-amber-400"><%= honey_icon(:shield, classes: "h-4 w-4") %></span>
                <p>Operationally simple setup with reusable templates and docs.</p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="bg-slate-950 py-16">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <h2 class="text-2xl font-semibold text-slate-100 sm:text-3xl">Implementation documentation</h2>
        <p class="mt-4 text-slate-300">
          All documentation to implement HoneyOps integrations is available at
          <a href="https://docs.honeyops.net" target="_blank" rel="noopener noreferrer" class="font-semibold text-amber-400 hover:underline">docs.honeyops.net</a>,
          including setup steps, required parameters, and operational guidance.
        </p>
      </div>
    </section>
  </main>

  <%= render "main/site_footer" %>
</div>
