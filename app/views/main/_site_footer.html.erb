          <div>
            <div class="font-semibold text-slate-100">Resources</div>
            <ul class="mt-3 space-y-2 text-slate-300">
              <li>
                <a href="https://docs.honeyops.net" target="_blank" rel="noopener noreferrer" class="hover:underline">
