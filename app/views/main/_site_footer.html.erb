              <li><%= link_to "Integrations", integrations_path, class: "hover:underline" %></li>
              <li><%= link_to "Pricing", pricing_path, class: "hover:underline" %></li>
              <li><%= link_to "FAQ", faq_path, class: "hover:underline" %></li>
              <li><%= link_to "Contact", contact_path, class: "hover:underline" %></li>
